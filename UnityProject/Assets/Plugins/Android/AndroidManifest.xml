<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.xgame.lazybrave">

    <!-- 合并片段：使用自定义的 Unity Activity（继承自 UnityPlayerActivity），
         以便拦截 onActivityResult 并将 Google Sign-In 结果回传给 Unity。
    -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <!-- 保持 Unity 启动 Activity，但替换为自定义实现以处理 onActivityResult -->
        <activity android:name="com.xgame.lazybrave.CustomUnityPlayerActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
